---
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="flex h-9 w-9 items-center justify-center rounded-full border border-border text-text-muted transition-all duration-200 hover:border-accent/40 hover:text-accent hover:shadow-sm hover:shadow-accent/10"
  aria-label={label}
>
  <slot />
</a>
