---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import CategoryIcon from "../atoms/CategoryIcon.astro";

interface Props {
  slug: string;
  name: string;
  description: string;
  accent: string;
  count: number;
  heroImage: ImageMetadata;
}

const { slug, name, description, accent, count, heroImage } = Astro.props;
---

<a
  href={`/catalog/${slug}`}
  class="franchise-card group relative block overflow-hidden rounded-2xl border border-border/50 transition-all duration-500 hover:border-white/15 hover:shadow-2xl hover:shadow-black/60"
  data-accent={accent}
>
  <!-- Hero background image -->
  <div class="relative aspect-[16/7] sm:aspect-[16/6] overflow-hidden">
    <Image
      src={heroImage}
      alt={`Colección ${name}`}
      widths={[480, 768, 1024]}
      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 100vw, 1024px"
      class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      loading="lazy"
      decoding="async"
    />

    <!-- Dark gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/55 to-black/30"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/20 to-transparent"></div>

    <!-- Accent edge glow -->
    <div
      class="absolute inset-x-0 bottom-0 h-[2px] opacity-60"
      style={`background: linear-gradient(90deg, ${accent}, transparent 70%)`}
    ></div>

    <!-- Content overlay -->
    <div class="absolute inset-0 flex flex-col justify-end p-5 sm:p-7">
      <!-- Category icon + badge -->
      <div class="mb-2 flex items-center gap-2">
        <div
          class="flex h-8 w-8 items-center justify-center rounded-lg backdrop-blur-sm sm:h-9 sm:w-9"
          style={`background:${accent}20; border: 1px solid ${accent}30`}
        >
          <CategoryIcon slug={slug} color={accent} class="h-4 w-4 sm:h-5 sm:w-5" />
        </div>
        <span
          class="rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider backdrop-blur-sm sm:text-xs"
          style={`background:${accent}20; color:${accent}; border: 1px solid ${accent}25`}
        >
          {count} diseños
        </span>
      </div>

      <!-- Title -->
      <h3 class="font-brand text-xl font-normal uppercase leading-tight tracking-tight text-white drop-shadow-lg sm:text-2xl lg:text-3xl">
        {name}
      </h3>
      <p class="mt-1 text-xs text-white/60 sm:text-sm">{description}</p>

      <!-- CTA -->
      <div class="mt-3 flex items-center gap-2 text-sm font-medium text-white/80 transition-all duration-300 group-hover:text-white group-hover:gap-3">
        <span>Ver colección</span>
        <svg width="16" height="16" class="transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    </div>
  </div>
</a>
