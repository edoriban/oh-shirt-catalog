---
import { Image } from "astro:assets";
import type { Product } from "../../data/products";
import { categories } from "../../data/categories";

interface Props {
  product: Product;
}

const { product } = Astro.props;
const category = categories.find((c) => c.slug === product.category);
const accent = category?.accent ?? "#e83e8c";
---

<article
  class="product-card card-shine group cursor-pointer rounded-2xl border border-border/50 bg-surface transition-all duration-300 hover:-translate-y-1 hover:border-white/10 hover:shadow-2xl hover:shadow-black/50"
  data-category={product.category}
  data-name={product.name}
  data-accent={accent}
  role="listitem"
  tabindex="0"
  aria-label={`Playera ${product.name} de ${category?.name ?? "Oh Shirt"}. Clic para vista rápida.`}
>
  <!-- Image container -->
  <div class="relative aspect-square overflow-hidden rounded-t-2xl">
    <Image
      src={product.image}
      alt={`Playera ${product.name}`}
      widths={[320, 480, 640]}
      sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
      class="h-full w-full object-cover transition-transform duration-600 ease-out group-hover:scale-[1.06]"
      loading="lazy"
      decoding="async"
    />

    <!-- Always-on subtle bottom gradient for readability -->
    <div class="pointer-events-none absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/50 to-transparent"></div>

    <!-- Hover overlay -->
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>

    <!-- Accent top bar — animates in from center -->
    <div
      class="absolute top-0 left-0 right-0 h-[3px] origin-center scale-x-0 transition-transform duration-400 ease-out group-hover:scale-x-100"
      style={`background: linear-gradient(90deg, transparent, ${accent}, transparent)`}
    ></div>

    <!-- Hover info (slides up) -->
    <div class="pointer-events-none absolute bottom-0 left-0 right-0 translate-y-1 p-3 opacity-0 transition-all duration-300 ease-out group-hover:translate-y-0 group-hover:opacity-100">
      <!-- Quick View button -->
      <div class="mb-2 flex justify-center">
        <span
          class="rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-semibold text-white backdrop-blur-md transition-all duration-200"
        >
          Vista rápida
        </span>
      </div>

      <p class="font-display text-sm font-semibold tracking-tight text-white drop-shadow-lg">{product.name}</p>
      <div class="mt-0.5 flex items-center gap-1.5">
        <div class="h-1.5 w-1.5 rounded-full" style={`background:${accent}; box-shadow: 0 0 6px ${accent}`}></div>
        <span class="text-[11px] text-white/60" data-category-label>{category?.name}</span>
      </div>
    </div>

    <!-- Expand icon (top right) -->
    <div class="pointer-events-none absolute top-2.5 right-2.5 flex h-7 w-7 items-center justify-center rounded-full bg-black/40 text-white/70 opacity-0 backdrop-blur-sm transition-all duration-300 group-hover:opacity-100">
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7"></path>
      </svg>
    </div>
  </div>

  <!-- Card footer — always visible product name -->
  <div class="px-3 py-3">
    <p class="truncate font-display text-xs font-semibold tracking-tight text-text transition-colors duration-200 sm:text-sm">{product.name}</p>
    <div class="mt-1 flex items-center gap-1.5">
      <div
        class="h-1.5 w-1.5 shrink-0 rounded-full"
        style={`background:${accent}`}
      ></div>
      <span class="text-[10px] text-text-muted sm:text-[11px]">{category?.name}</span>
    </div>
  </div>
</article>
