---
import CategoryIcon from "../atoms/CategoryIcon.astro";

interface Props {
  name: string;
  description: string;
  accent: string;
  count: number;
  slug: string;
}

const { name, description, accent, count, slug } = Astro.props;
---

<div
  class="category-header col-span-full flex items-center gap-4 pt-10 pb-3"
  data-category-header={slug}
>
  <!-- Category icon -->
  <div
    class="flex size-9 shrink-0 items-center justify-center rounded-lg"
    style={`background:${accent}15; border: 1px solid ${accent}25`}
  >
    <CategoryIcon slug={slug} color={accent} class="size-5" />
  </div>

  <div class="flex-1">
    <h2 class="font-brand text-xl font-normal uppercase tracking-tight text-text sm:text-2xl">{name}</h2>
    <p class="mt-0.5 text-xs text-text-muted">{description}</p>
  </div>

  <!-- Count badge -->
  <span
    class="rounded-full px-3 py-1 font-display text-xs font-semibold tabular-nums"
    style={`background:${accent}15; color:${accent}; border: 1px solid ${accent}25`}
  >
    {count} diseños
  </span>
</div>
