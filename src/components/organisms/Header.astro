---
import Logo from "../atoms/Logo.astro";
import SocialLink from "../atoms/SocialLink.astro";

const navLinks = [
  { href: "/catalog/todos", label: "Catálogo" },
  { href: "/faq", label: "FAQ" },
  { href: "/contacto", label: "Contacto" },
  { href: "/politicas", label: "Políticas" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 border-b border-white/[0.06] bg-bg/60 backdrop-blur-2xl"
  style="box-shadow: 0 1px 30px rgba(0,0,0,0.3), inset 0 -1px 0 rgba(255,255,255,0.03)"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-2.5 sm:px-6">
    <a href="/catalog" class="flex shrink-0 items-center gap-2.5 transition-opacity hover:opacity-80">
      <Logo size="md" />
      <span class="font-brand text-sm uppercase tracking-wider text-text sm:text-base">Oh! Shirt</span>
    </a>

    <nav class="flex items-center gap-2 md:gap-3" aria-label="Navegación principal">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="hidden font-display text-[11px] font-medium uppercase tracking-widest text-text-muted transition-colors hover:text-text md:block"
        >
          {link.label}
        </a>
      ))}

      <!-- Search button (desktop) -->
      <button
        id="search-btn-desktop"
        type="button"
        class="hidden items-center gap-2 rounded-xl border border-white/10 bg-white/[0.04] px-3 py-1.5 text-[11px] font-medium text-text-muted transition-all duration-200 hover:border-white/20 hover:bg-white/[0.07] hover:text-text md:flex"
        aria-label="Buscar productos"
      >
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <span>Buscar</span>
        <kbd class="rounded border border-white/10 bg-white/[0.06] px-1.5 py-0.5 font-mono text-[10px] leading-none text-text-muted/60">⌘K</kbd>
      </button>

      <div class="hidden h-4 w-px bg-white/[0.08] md:block"></div>

      <!-- Instagram: visible on desktop, hidden on mobile (accessible via hamburger) -->
      <div class="hidden md:block">
        <SocialLink href="https://www.instagram.com/oh_shirt_print/" label="Instagram">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"></path>
          </svg>
        </SocialLink>
      </div>

      <!-- Search button (mobile) -->
      <button
        id="search-btn-mobile"
        type="button"
        class="flex h-11 w-11 items-center justify-center rounded-xl border border-white/20 bg-white/10 text-white backdrop-blur-sm transition-all duration-200 active:scale-95 md:hidden"
        aria-label="Buscar productos"
      >
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>

      <!-- Mobile hamburger button -->
      <button
        id="menu-toggle"
        class="flex h-11 w-11 items-center justify-center rounded-xl border border-white/20 bg-white/10 text-white backdrop-blur-sm transition-all duration-200 active:scale-95 md:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
        </svg>
        <svg id="menu-icon-close" width="22" height="22" style="display:none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="pointer-events-none fixed inset-0 z-40 opacity-0 transition-opacity duration-300"
  aria-hidden="true"
>
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-bg/80 backdrop-blur-xl"></div>

  <!-- Menu content -->
  <nav class="relative flex h-full flex-col items-center justify-center gap-5 px-8">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="mobile-menu-link w-full max-w-xs translate-y-4 rounded-2xl border border-white/[0.06] bg-white/[0.03] px-6 py-4 text-center font-display text-sm font-medium uppercase tracking-widest text-text opacity-0 transition-all duration-300 hover:border-accent/30 hover:bg-accent/10 hover:text-accent"
        style="box-shadow: 0 4px 20px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.04)"
      >
        {link.label}
      </a>
    ))}

    <div class="mt-2 flex items-center gap-3">
      <SocialLink href="https://www.instagram.com/oh_shirt_print/" label="Instagram">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"></path>
        </svg>
      </SocialLink>
    </div>
  </nav>
</div>

<script is:inline>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  const links = menu.querySelectorAll('.mobile-menu-link');
  let isOpen = false;

  function openMenu() {
    isOpen = true;
    menu.classList.remove('pointer-events-none', 'opacity-0');
    menu.classList.add('pointer-events-auto', 'opacity-100');
    menu.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
    iconOpen.style.display = 'none';
    iconClose.style.display = '';
    document.body.style.overflow = 'hidden';
    links.forEach(function(link, i) {
      setTimeout(function() {
        link.style.opacity = '1';
        link.style.transform = 'translateY(0)';
      }, 50 + i * 60);
    });
  }

  function closeMenu() {
    isOpen = false;
    menu.classList.add('pointer-events-none', 'opacity-0');
    menu.classList.remove('pointer-events-auto', 'opacity-100');
    menu.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    iconOpen.style.display = '';
    iconClose.style.display = 'none';
    document.body.style.overflow = '';
    links.forEach(function(link) {
      link.style.opacity = '0';
      link.style.transform = 'translateY(1rem)';
    });
  }

  toggle.addEventListener('click', function() {
    if (isOpen) closeMenu();
    else openMenu();
  });

  links.forEach(function(link) {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });

  // Global search buttons
  var searchDesktop = document.getElementById('search-btn-desktop');
  var searchMobile = document.getElementById('search-btn-mobile');

  function triggerSearch() {
    if (isOpen) closeMenu();
    if (window.__openGlobalSearch) window.__openGlobalSearch();
  }

  if (searchDesktop) searchDesktop.addEventListener('click', triggerSearch);
  if (searchMobile) searchMobile.addEventListener('click', triggerSearch);
</script>
