<!-- Hide animated elements until GSAP takes over -->
<style>
  #hero-title,
  #hero-subtitle,
  #featured-title,
  #franchises-title,
  .filter-pill {
    visibility: hidden;
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);
  (window as any).ScrollTrigger = ScrollTrigger;

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (prefersReduced) {
    gsap.set(
      "#hero-title, #hero-subtitle, #featured-title, #franchises-title, .filter-pill",
      { visibility: "visible" }
    );
  } else {
    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

    tl.fromTo(
      "#hero-title",
      { autoAlpha: 0, y: 40, scale: 0.95 },
      { autoAlpha: 1, y: 0, scale: 1, duration: 0.9 }
    )
      .fromTo(
        "#hero-subtitle",
        { autoAlpha: 0, y: 25 },
        { autoAlpha: 1, y: 0, duration: 0.7 },
        "-=0.5"
      )
      .fromTo(
        ".filter-pill",
        { autoAlpha: 0, y: 10, scale: 0.95 },
        { autoAlpha: 1, y: 0, scale: 1, duration: 0.35, stagger: 0.05 },
        "-=0.3"
      );

    // Featured section title
    const featuredTitle = document.getElementById("featured-title");
    if (featuredTitle) {
      gsap.fromTo(
        "#featured-title",
        { autoAlpha: 0, y: 15 },
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.5,
          ease: "power2.out",
          scrollTrigger: {
            trigger: "#featured-title",
            start: "top 90%",
            toggleActions: "play none none none",
          },
        }
      );
    }

    // Featured product cards stagger
    const featuredGrid = document.getElementById("featured-grid");
    if (featuredGrid) {
      gsap.fromTo(
        "#featured-grid .product-card",
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.5,
          stagger: 0.08,
          ease: "power2.out",
          scrollTrigger: {
            trigger: "#featured-grid",
            start: "top 88%",
            toggleActions: "play none none none",
          },
        }
      );
    }

    // Franchises section title
    const franchisesTitle = document.getElementById("franchises-title");
    if (franchisesTitle) {
      gsap.fromTo(
        "#franchises-title",
        { autoAlpha: 0, y: 15 },
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.5,
          ease: "power2.out",
          scrollTrigger: {
            trigger: "#franchises-title",
            start: "top 90%",
            toggleActions: "play none none none",
          },
        }
      );
    }

    // Franchise hero cards stagger
    const franchiseGrid = document.getElementById("franchise-grid");
    if (franchiseGrid) {
      gsap.fromTo(
        ".franchise-card",
        { y: 40, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.6,
          stagger: 0.1,
          ease: "power2.out",
          scrollTrigger: {
            trigger: "#franchise-grid",
            start: "top 85%",
            toggleActions: "play none none none",
          },
        }
      );
    }

    // Category headers (for category filter pages)
    gsap.utils.toArray<HTMLElement>(".category-header").forEach((header) => {
      gsap.fromTo(
        header,
        { x: -20, opacity: 0 },
        {
          x: 0,
          opacity: 1,
          duration: 0.5,
          ease: "power2.out",
          scrollTrigger: {
            trigger: header,
            start: "top 88%",
            toggleActions: "play none none none",
          },
        }
      );
    });

    // Batch reveal for product cards (in ProductGrid)
    ScrollTrigger.batch(".product-card[data-revealed]", {
      onEnter: (batch) => {
        gsap.fromTo(
          batch,
          { y: 30, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 0.5,
            stagger: 0.05,
            ease: "power2.out",
            overwrite: true,
          }
        );
      },
      start: "top 92%",
    });
  }
</script>
