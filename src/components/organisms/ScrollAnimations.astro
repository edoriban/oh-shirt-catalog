<!-- Hide animated elements until GSAP takes over -->
<style>
  #hero-eyebrow,
  #hero-title,
  #hero-subtitle,
  .filter-pill {
    visibility: hidden;
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);
  (window as any).ScrollTrigger = ScrollTrigger;

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (prefersReduced) {
    gsap.set(
      "#hero-eyebrow, #hero-title, #hero-subtitle, .filter-pill",
      { visibility: "visible" }
    );
  } else {
    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

    tl.fromTo(
      "#hero-eyebrow",
      { autoAlpha: 0, y: 20 },
      { autoAlpha: 1, y: 0, duration: 0.6 }
    )
      .fromTo(
        "#hero-title",
        { autoAlpha: 0, y: 40, scale: 0.97 },
        { autoAlpha: 1, y: 0, scale: 1, duration: 0.8 },
        "-=0.4"
      )
      .fromTo(
        "#hero-subtitle",
        { autoAlpha: 0, y: 25 },
        { autoAlpha: 1, y: 0, duration: 0.7 },
        "-=0.5"
      )
      .fromTo(
        ".filter-pill",
        { autoAlpha: 0, y: 10, scale: 0.95 },
        { autoAlpha: 1, y: 0, scale: 1, duration: 0.35, stagger: 0.05 },
        "-=0.3"
      );

    // Category headers slide in
    gsap.utils.toArray<HTMLElement>(".category-header").forEach((header) => {
      gsap.fromTo(
        header,
        { x: -20, opacity: 0 },
        {
          x: 0,
          opacity: 1,
          duration: 0.5,
          ease: "power2.out",
          scrollTrigger: {
            trigger: header,
            start: "top 88%",
            toggleActions: "play none none none",
          },
        }
      );
    });

    // Batch reveal for product cards
    ScrollTrigger.batch(".product-card[data-revealed]", {
      onEnter: (batch) => {
        gsap.fromTo(
          batch,
          { y: 30, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 0.5,
            stagger: 0.05,
            ease: "power2.out",
            overwrite: true,
          }
        );
      },
      start: "top 92%",
    });
  }
</script>
