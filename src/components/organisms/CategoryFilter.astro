---
import { categories } from "../../data/categories";
import FilterPill from "../molecules/FilterPill.astro";

const totalCount = categories.reduce((sum, c) => sum + c.count, 0);
---

<div class="sticky top-[53px] z-40 border-b border-border/60 bg-bg/90 backdrop-blur-xl">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div
      id="category-filters"
      class="flex gap-2 overflow-x-auto py-3 scrollbar-none"
      role="tablist"
    >
      <FilterPill filter="all" label="Todos" count={totalCount} active />

      {categories.map((cat) => (
        <FilterPill
          filter={cat.slug}
          label={cat.name}
          count={cat.count}
          accent={cat.accent}
        />
      ))}
    </div>
  </div>
</div>

<!-- Active category banner (hidden by default, shown on filter) -->
<div
  id="category-banner"
  class="mx-auto hidden max-w-7xl px-4 pt-6 sm:px-6"
>
  <div
    id="category-banner-inner"
    class="flex items-center gap-3 rounded-xl border border-border/40 bg-surface/50 px-4 py-3"
  >
    <div id="category-banner-bar" class="h-8 w-1 rounded-full"></div>
    <div class="flex-1">
      <h2 id="category-banner-title" class="text-lg font-bold text-text"></h2>
      <p id="category-banner-desc" class="text-xs text-text-muted"></p>
    </div>
    <span id="category-banner-count" class="rounded-full px-2.5 py-0.5 text-xs font-semibold"></span>
  </div>
</div>

<script>
  import { categories } from "../../data/categories";

  const categoryMap = new Map(categories.map((c) => [c.slug, c]));

  function initFilters() {
    const pills = document.querySelectorAll<HTMLButtonElement>(".filter-pill");
    const grid = document.getElementById("product-grid")!;
    const noResults = document.getElementById("no-results");
    const sentinel = document.getElementById("load-sentinel");
    const template = document.getElementById("remaining-cards") as HTMLTemplateElement | null;
    const banner = document.getElementById("category-banner")!;
    const bannerBar = document.getElementById("category-banner-bar")!;
    const bannerTitle = document.getElementById("category-banner-title")!;
    const bannerDesc = document.getElementById("category-banner-desc")!;
    const bannerCount = document.getElementById("category-banner-count")!;

    function loadAllRemaining() {
      if (!template || template.content.children.length === 0) return;
      const fragment = document.createDocumentFragment();
      Array.from(template.content.children).forEach((node) => {
        const clone = node.cloneNode(true) as HTMLElement;
        clone.setAttribute("data-revealed", "true");
        fragment.appendChild(clone);
      });
      grid.appendChild(fragment);
      template.innerHTML = "";
      if (sentinel) sentinel.style.display = "none";

      // Attach lightbox listeners to new cards
      if ((window as any).__attachCardListeners) {
        const newCards = Array.from(grid.querySelectorAll<HTMLElement>(".product-card:not([data-lb])"));
        (window as any).__attachCardListeners(newCards);
      }
    }

    function showBanner(slug: string) {
      const cat = categoryMap.get(slug);
      if (!cat) return;
      bannerBar.style.background = cat.accent;
      bannerTitle.textContent = cat.name;
      bannerDesc.textContent = cat.description;
      bannerCount.textContent = String(cat.count);
      bannerCount.style.background = cat.accent + "20";
      bannerCount.style.color = cat.accent;
      banner.classList.remove("hidden");
    }

    function hideBanner() {
      banner.classList.add("hidden");
    }

    pills.forEach((pill) => {
      pill.addEventListener("click", () => {
        const filter = pill.dataset.filter!;

        // Update pill styles
        pills.forEach((p) => {
          p.classList.remove("active", "border-accent", "bg-accent/15", "text-accent", "font-semibold");
          p.classList.add("border-border", "text-text-muted", "font-medium");
          p.setAttribute("aria-selected", "false");
        });
        pill.classList.add("active", "border-accent", "bg-accent/15", "text-accent", "font-semibold");
        pill.classList.remove("border-border", "text-text-muted", "font-medium");
        pill.setAttribute("aria-selected", "true");

        // Show/hide category banner
        if (filter !== "all") {
          loadAllRemaining();
          showBanner(filter);
        } else {
          hideBanner();
        }

        // Re-query cards
        const cards = grid.querySelectorAll<HTMLElement>(".product-card");
        let visibleCount = 0;

        cards.forEach((card) => {
          const category = card.dataset.category;
          const show = filter === "all" || category === filter;
          if (show) {
            card.style.display = "";
            visibleCount++;
          } else {
            card.style.display = "none";
          }
        });

        // Also hide category headers when filtering
        grid.querySelectorAll<HTMLElement>(".category-header").forEach((h) => {
          if (filter === "all") {
            h.style.display = "";
          } else {
            h.style.display = "none";
          }
        });

        if (noResults) {
          noResults.style.display = visibleCount === 0 ? "block" : "none";
        }

        if (filter === "all" && sentinel && template && template.content.children.length > 0) {
          sentinel.style.display = "flex";
        }

        if ((window as any).ScrollTrigger) {
          (window as any).ScrollTrigger.refresh();
        }
      });
    });
  }

  initFilters();
</script>

<style>
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
