---
import HeroBackground from "../HeroBackground";
---

<section class="relative overflow-hidden pb-6 pt-20 sm:pb-14 sm:pt-36">
  <!-- PixelBlast background (desktop only, respects reduced-motion) -->
  <div class="pointer-events-none absolute inset-0 hidden sm:block">
    <HeroBackground client:only="react" />
  </div>

  <!-- Mobile-only CSS fallback background -->
  <div class="pointer-events-none absolute inset-0 sm:hidden" aria-hidden="true">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[70%] w-[80%] rounded-full bg-accent/[0.06] blur-[80px]"></div>
    <div class="absolute bottom-0 left-1/4 h-32 w-48 rounded-full bg-accent/[0.04] blur-[60px]"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 text-center sm:px-6">
    <!-- Logo -->
    <div id="hero-title" class="mb-4 sm:mb-6">
      <img
        src="/logo.jpg"
        alt="Oh Shirt!"
        class="mx-auto h-36 w-36 rounded-full object-cover sm:h-56 sm:w-56 lg:h-72 lg:w-72"
        style="filter: drop-shadow(0 0 50px rgba(232,62,140,0.15))"
      />
    </div>

    <!-- Subtitle badge -->
    <div id="hero-subtitle" class="flex justify-center">
      <p
        class="inline-block rounded-2xl border border-accent/20 bg-accent/10 px-4 py-2.5 text-[13px] leading-relaxed text-text backdrop-blur-xl sm:px-6 sm:py-3 sm:text-base"
        style="box-shadow: 0 4px 30px rgba(232, 62, 140, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.05)"
      >
        Diseños exclusivos de tus franquicias favoritas.<br class="hidden sm:block" />
        <span class="hidden sm:inline">Encuentra tu estilo, presume tu fandom.</span>
      </p>
    </div>

    <!-- CTA button (mobile-prominent, subtler on desktop) -->
    <div class="mt-5 flex justify-center sm:hidden">
      <a
        href="/catalog/todos"
        class="group inline-flex items-center gap-2 rounded-full border border-accent/40 bg-accent/10 px-5 py-2.5 font-display text-xs font-semibold uppercase tracking-wider text-accent backdrop-blur-sm transition-all duration-300 hover:bg-accent hover:text-white sm:px-6 sm:py-3 sm:text-sm"
        style="box-shadow: 0 2px 20px rgba(232,62,140,0.1)"
      >
        Explorar catálogo
        <svg width="16" height="16" class="transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>

    <!-- Scroll indicator (mobile only) -->
    <div class="mt-6 flex justify-center sm:hidden" aria-hidden="true">
      <div class="scroll-indicator flex flex-col items-center gap-1 text-text-muted/40">
        <span class="text-[9px] uppercase tracking-[0.2em]">Scroll</span>
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
        </svg>
      </div>
    </div>
  </div>
</section>

<style is:global>
  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.4; }
    50% { transform: translateY(4px); opacity: 0.7; }
  }

  .scroll-indicator svg {
    animation: scroll-bounce 2s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-indicator svg {
      animation: none;
    }
  }
</style>
