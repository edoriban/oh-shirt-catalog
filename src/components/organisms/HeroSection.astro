---
---

<section class="relative overflow-hidden pb-8 pt-28 sm:pb-14 sm:pt-36">
  <!-- Mesh gradient background -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-0 left-1/2 h-[500px] w-[800px] -translate-x-1/2 -translate-y-1/4 rounded-full bg-accent/[0.07] blur-[120px]"></div>
    <div class="absolute top-32 right-0 h-72 w-72 rounded-full bg-purple-600/[0.04] blur-[100px]"></div>
    <div class="absolute top-40 left-0 h-60 w-60 rounded-full bg-orange-500/[0.03] blur-[80px]"></div>
  </div>

  <!-- Grid pattern overlay -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.03]"
    style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;"
  ></div>

  <div class="relative mx-auto max-w-7xl px-4 text-center sm:px-6">
    <!-- Logo -->
    <div id="hero-title" class="mb-6">
      <img
        src="/logo.jpg"
        alt="Oh Shirt!"
        class="mx-auto h-40 w-auto rounded-xl sm:h-52 lg:h-64"
        style="filter: drop-shadow(0 0 50px rgba(232,62,140,0.15))"
      />
    </div>

    <!-- Subtitle -->
    <p
      id="hero-subtitle"
      class="mx-auto mb-6 max-w-lg text-base leading-relaxed text-text-muted sm:text-lg"
    >
      Diseños exclusivos de tus franquicias favoritas.<br class="hidden sm:block" />
      Encuentra tu estilo, presume tu fandom.
    </p>
  </div>
</section>
