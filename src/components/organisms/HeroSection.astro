---
import HeroBackground from "../HeroBackground";
---

<section class="relative overflow-hidden pb-8 pt-28 sm:pb-14 sm:pt-36">
  <!-- PixelBlast background -->
  <div class="pointer-events-none absolute inset-0">
    <HeroBackground client:only="react" />
  </div>

  <div class="relative mx-auto max-w-7xl px-4 text-center sm:px-6">
    <!-- Logo -->
    <div id="hero-title" class="mb-6">
      <img
        src="/logo.jpg"
        alt="Oh Shirt!"
        class="mx-auto h-44 w-44 rounded-full object-cover sm:h-56 sm:w-56 lg:h-72 lg:w-72"
        style="filter: drop-shadow(0 0 50px rgba(232,62,140,0.15))"
      />
    </div>

    <!-- Subtitle badge -->
    <div id="hero-subtitle" class="flex justify-center">
      <p
        class="inline-block rounded-2xl border border-accent/20 bg-accent/10 px-6 py-3 text-sm leading-relaxed text-text backdrop-blur-xl sm:text-base"
        style="box-shadow: 0 4px 30px rgba(232, 62, 140, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.05)"
      >
        Diseños exclusivos de tus franquicias favoritas.<br class="hidden sm:block" />
        Encuentra tu estilo, presume tu fandom.
      </p>
    </div>
  </div>
</section>
