---
import { getAllProducts } from "../../data/products";
import { categories } from "../../data/categories";

const products = getAllProducts();
const categoryMap = new Map(categories.map((c) => [c.slug, c]));

// Lightweight serialized data for client-side search (~3KB gzipped)
const searchData = products.map((p) => {
  const cat = categoryMap.get(p.category);
  return {
    id: p.id,
    name: p.name,
    category: p.category,
    categoryName: cat?.name ?? "",
    accent: cat?.accent ?? "#e83e8c",
    image: p.image.src,
  };
});
---

<!-- Global Search Overlay -->
<div
  id="global-search"
  class="pointer-events-none fixed inset-0 z-[70] opacity-0 transition-opacity duration-200"
  role="dialog"
  aria-modal="true"
  aria-label="Buscar productos"
  aria-hidden="true"
>
  <!-- Backdrop -->
  <div id="global-search-backdrop" class="absolute inset-0 bg-bg/80 backdrop-blur-xl"></div>

  <!-- Panel -->
  <div class="relative flex h-full items-start justify-center px-4 pt-[15vh] sm:pt-[20vh]">
    <div
      id="global-search-panel"
      class="w-full max-w-lg scale-95 rounded-2xl border border-white/[0.08] bg-surface/95 shadow-2xl shadow-black/60 backdrop-blur-2xl transition-transform duration-200"
      style="box-shadow: 0 25px 50px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.05)"
    >
      <!-- Search input -->
      <div class="relative border-b border-white/[0.06] px-4 py-3">
        <svg
          width="18" height="18"
          class="pointer-events-none absolute top-1/2 left-4 -translate-y-1/2 text-text-muted"
          fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          id="global-search-input"
          type="search"
          placeholder="Buscar playeras..."
          autocomplete="off"
          class="w-full bg-transparent py-1 pl-8 pr-10 text-sm text-text placeholder-text-muted/60 outline-none"
          aria-label="Buscar playeras por nombre o franquicia"
          aria-controls="global-search-results"
          aria-autocomplete="list"
          role="combobox"
          aria-expanded="false"
          aria-haspopup="listbox"
        />
        <!-- Close button -->
        <button
          id="global-search-close"
          type="button"
          class="absolute top-1/2 right-4 -translate-y-1/2 flex h-6 w-6 items-center justify-center rounded-md text-text-muted transition-colors hover:bg-white/[0.08] hover:text-text"
          aria-label="Cerrar búsqueda"
        >
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Results area -->
      <div id="global-search-results-area" class="max-h-[50vh] overflow-y-auto overscroll-contain">
        <!-- Empty state: category suggestions -->
        <div id="global-search-empty" class="px-4 py-5">
          <p class="mb-3 text-xs font-medium uppercase tracking-wider text-text-muted">Explorar categorías</p>
          <div class="flex flex-wrap gap-2" id="global-search-categories"></div>
        </div>

        <!-- Results list -->
        <ul
          id="global-search-results"
          class="hidden"
          role="listbox"
          aria-label="Resultados de búsqueda"
        ></ul>

        <!-- No results -->
        <div id="global-search-no-results" class="hidden px-4 py-8 text-center">
          <p class="text-sm text-text-muted">No se encontraron resultados</p>
          <p class="mt-1 text-xs text-text-muted/60">Intenta con otro nombre o franquicia</p>
        </div>
      </div>

      <!-- Result count (screen reader) -->
      <div id="global-search-live" class="sr-only" aria-live="polite" aria-atomic="true"></div>

      <!-- Footer hints -->
      <div class="flex items-center gap-4 border-t border-white/[0.06] px-4 py-2.5">
        <span class="flex items-center gap-1 text-[10px] text-text-muted/60">
          <kbd class="rounded border border-white/10 bg-white/[0.04] px-1 py-0.5 font-mono text-[10px]">&uarr;&darr;</kbd>
          navegar
        </span>
        <span class="flex items-center gap-1 text-[10px] text-text-muted/60">
          <kbd class="rounded border border-white/10 bg-white/[0.04] px-1 py-0.5 font-mono text-[10px]">&crarr;</kbd>
          abrir
        </span>
        <span class="flex items-center gap-1 text-[10px] text-text-muted/60">
          <kbd class="rounded border border-white/10 bg-white/[0.04] px-1 py-0.5 font-mono text-[10px]">esc</kbd>
          cerrar
        </span>
      </div>
    </div>
  </div>
</div>

<!-- Embedded product data -->
<script type="application/json" id="global-search-data" set:html={JSON.stringify(searchData)} />

<script is:inline>
(function() {
  var overlay = document.getElementById('global-search');
  var backdrop = document.getElementById('global-search-backdrop');
  var panel = document.getElementById('global-search-panel');
  var input = document.getElementById('global-search-input');
  var resultsArea = document.getElementById('global-search-results-area');
  var resultsList = document.getElementById('global-search-results');
  var emptyState = document.getElementById('global-search-empty');
  var noResults = document.getElementById('global-search-no-results');
  var categoriesContainer = document.getElementById('global-search-categories');
  var liveRegion = document.getElementById('global-search-live');

  var data = JSON.parse(document.getElementById('global-search-data').textContent);
  var isOpen = false;
  var activeIndex = -1;
  var currentResults = [];
  var MAX_RESULTS = 20;

  // Extract unique categories from data
  var categorySet = {};
  data.forEach(function(p) {
    if (!categorySet[p.category]) {
      categorySet[p.category] = { slug: p.category, name: p.categoryName, accent: p.accent };
    }
  });

  // Build category suggestion buttons
  Object.values(categorySet).forEach(function(cat) {
    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'flex items-center gap-1.5 rounded-lg border border-white/[0.06] bg-white/[0.03] px-3 py-1.5 text-xs text-text-muted transition-colors duration-150 hover:border-white/15 hover:bg-white/[0.06] hover:text-text';
    btn.innerHTML = '<span class="h-2 w-2 rounded-full shrink-0" style="background:' + cat.accent + '"></span>' + cat.name;
    btn.addEventListener('click', function() {
      input.value = cat.name;
      input.dispatchEvent(new Event('input'));
      input.focus();
    });
    categoriesContainer.appendChild(btn);
  });

  function open() {
    if (isOpen) return;
    isOpen = true;
    overlay.classList.remove('pointer-events-none', 'opacity-0');
    overlay.classList.add('pointer-events-auto', 'opacity-100');
    overlay.setAttribute('aria-hidden', 'false');
    panel.classList.remove('scale-95');
    panel.classList.add('scale-100');
    document.body.style.overflow = 'hidden';
    input.value = '';
    activeIndex = -1;
    currentResults = [];
    showEmpty();
    // Small delay to allow transition before focusing
    setTimeout(function() { input.focus(); }, 50);
  }

  function close() {
    if (!isOpen) return;
    isOpen = false;
    overlay.classList.add('pointer-events-none', 'opacity-0');
    overlay.classList.remove('pointer-events-auto', 'opacity-100');
    overlay.setAttribute('aria-hidden', 'true');
    panel.classList.add('scale-95');
    panel.classList.remove('scale-100');
    document.body.style.overflow = '';
    activeIndex = -1;
  }

  function showEmpty() {
    emptyState.classList.remove('hidden');
    resultsList.classList.add('hidden');
    noResults.classList.add('hidden');
    input.setAttribute('aria-expanded', 'false');
  }

  function showResults() {
    emptyState.classList.add('hidden');
    resultsList.classList.remove('hidden');
    noResults.classList.add('hidden');
    input.setAttribute('aria-expanded', 'true');
  }

  function showNoResults() {
    emptyState.classList.add('hidden');
    resultsList.classList.add('hidden');
    noResults.classList.remove('hidden');
    input.setAttribute('aria-expanded', 'false');
  }

  function highlightMatch(text, query) {
    if (!query) return text;
    var lower = text.toLowerCase();
    var idx = lower.indexOf(query.toLowerCase());
    if (idx === -1) return text;
    var before = text.slice(0, idx);
    var match = text.slice(idx, idx + query.length);
    var after = text.slice(idx + query.length);
    return before + '<mark class="bg-accent/30 text-text rounded-sm px-0.5">' + match + '</mark>' + after;
  }

  function renderResults(query) {
    var q = query.toLowerCase().trim();

    if (!q) {
      currentResults = [];
      activeIndex = -1;
      showEmpty();
      liveRegion.textContent = '';
      return;
    }

    currentResults = data.filter(function(p) {
      return p.name.toLowerCase().includes(q) || p.categoryName.toLowerCase().includes(q);
    }).slice(0, MAX_RESULTS);

    if (currentResults.length === 0) {
      activeIndex = -1;
      showNoResults();
      liveRegion.textContent = 'No se encontraron resultados para ' + query;
      return;
    }

    resultsList.innerHTML = '';
    currentResults.forEach(function(product, i) {
      var li = document.createElement('li');
      li.role = 'option';
      li.id = 'gs-result-' + i;
      li.setAttribute('aria-selected', 'false');
      li.className = 'gs-result flex cursor-pointer items-center gap-3 px-4 py-2.5 transition-colors duration-100 hover:bg-white/[0.04]';
      li.dataset.index = String(i);
      li.dataset.category = product.category;

      li.innerHTML =
        '<img src="' + product.image + '" alt="" width="40" height="40" class="h-10 w-10 shrink-0 rounded-lg object-cover" loading="lazy" />' +
        '<div class="min-w-0 flex-1">' +
          '<p class="truncate text-sm font-medium text-text">' + highlightMatch(product.name, query) + '</p>' +
          '<div class="mt-0.5 flex items-center gap-1.5">' +
            '<span class="h-1.5 w-1.5 shrink-0 rounded-full" style="background:' + product.accent + '"></span>' +
            '<span class="text-[11px] text-text-muted">' + product.categoryName + '</span>' +
          '</div>' +
        '</div>' +
        '<svg width="14" height="14" class="shrink-0 text-text-muted/40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>';

      li.addEventListener('click', function() {
        navigateToResult(i);
      });

      resultsList.appendChild(li);
    });

    activeIndex = -1;
    showResults();
    liveRegion.textContent = currentResults.length + ' resultado' + (currentResults.length !== 1 ? 's' : '') + ' para ' + query;
  }

  function updateActiveItem() {
    var items = resultsList.querySelectorAll('.gs-result');
    items.forEach(function(item, i) {
      if (i === activeIndex) {
        item.classList.add('bg-white/[0.06]');
        item.setAttribute('aria-selected', 'true');
        input.setAttribute('aria-activedescendant', item.id);
        // Scroll into view if needed
        item.scrollIntoView({ block: 'nearest' });
      } else {
        item.classList.remove('bg-white/[0.06]');
        item.setAttribute('aria-selected', 'false');
      }
    });
    if (activeIndex === -1) {
      input.removeAttribute('aria-activedescendant');
    }
  }

  function navigateToResult(index) {
    var product = currentResults[index];
    if (product) {
      window.location.href = '/catalog/' + product.category;
    }
  }

  // Input handler
  input.addEventListener('input', function() {
    renderResults(input.value);
  });

  // Keyboard navigation
  input.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (currentResults.length > 0) {
        activeIndex = (activeIndex + 1) % currentResults.length;
        updateActiveItem();
      }
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (currentResults.length > 0) {
        activeIndex = activeIndex <= 0 ? currentResults.length - 1 : activeIndex - 1;
        updateActiveItem();
      }
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (activeIndex >= 0 && currentResults[activeIndex]) {
        navigateToResult(activeIndex);
      } else if (input.value.trim()) {
        window.location.href = '/catalog/todos?q=' + encodeURIComponent(input.value.trim());
      }
    } else if (e.key === 'Escape') {
      e.preventDefault();
      close();
    }
  });

  // Close on backdrop click or close button
  backdrop.addEventListener('click', close);
  document.getElementById('global-search-close').addEventListener('click', close);

  // Global keyboard shortcut: Ctrl/Cmd+K
  document.addEventListener('keydown', function(e) {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (isOpen) close();
      else open();
    }
    if (e.key === 'Escape' && isOpen) {
      e.preventDefault();
      close();
    }
  });

  // Expose global open function for header buttons
  window.__openGlobalSearch = open;
  window.__closeGlobalSearch = close;
})();
</script>

<style>
  #global-search-results-area::-webkit-scrollbar {
    width: 4px;
  }
  #global-search-results-area::-webkit-scrollbar-track {
    background: transparent;
  }
  #global-search-results-area::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.08);
    border-radius: 2px;
  }
  #global-search-results-area::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  @media (prefers-reduced-motion: reduce) {
    #global-search,
    #global-search-panel {
      transition-duration: 0.01ms !important;
    }
  }
</style>
