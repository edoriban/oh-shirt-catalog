---
import Layout from "../layouts/Layout.astro";
import Header from "../components/organisms/Header.astro";
import Footer from "../components/organisms/Footer.astro";
import WhatsAppButton from "../components/organisms/WhatsAppButton.astro";
import Breadcrumb from "../components/atoms/Breadcrumb.astro";

const breadcrumbs = [
  { label: "Inicio", href: "/catalog" },
  { label: "Preguntas Frecuentes" },
];

const faqs = [
  {
    question: "¿Cómo hago un pedido?",
    answer: "Navega nuestro catálogo, elige el diseño que te guste y contáctanos por WhatsApp. Te confirmaremos disponibilidad, talla y forma de pago. ¡Es súper fácil!",
  },
  {
    question: "¿Qué tallas manejan?",
    answer: "Manejamos tallas S, M, L, XL y XXL. Todas nuestras playeras son unisex con corte regular. Si tienes dudas sobre cuál elegir, con gusto te orientamos por WhatsApp.",
  },
  {
    question: "¿De qué material son las playeras?",
    answer: "Usamos algodón premium de alta calidad. Son suaves, cómodas y resistentes a múltiples lavadas. La impresión se realiza con técnicas de sublimación y DTF para garantizar colores vibrantes y durabilidad.",
  },
  {
    question: "¿Hacen envíos a toda la República?",
    answer: "¡Sí! Enviamos a todo México. El costo y tiempo de envío varía según tu ubicación. Envíos locales (Monterrey y área metropolitana) pueden ser el mismo día o al día siguiente.",
  },
  {
    question: "¿Cuánto tarda en llegar mi pedido?",
    answer: "Pedidos locales (Monterrey): 1-2 días hábiles. Envíos nacionales: 3-7 días hábiles dependiendo de la zona. Te proporcionamos número de guía para que puedas rastrear tu paquete.",
  },
  {
    question: "¿Puedo pedir un diseño personalizado?",
    answer: "¡Claro! Podemos crear diseños personalizados para ti. Escríbenos por WhatsApp con tu idea y te daremos una cotización. También hacemos pedidos por mayoreo para eventos o grupos.",
  },
  {
    question: "¿Qué métodos de pago aceptan?",
    answer: "Aceptamos transferencia bancaria, depósito en OXXO y pago con tarjeta a través de un link de pago seguro. El pago se realiza antes del envío.",
  },
  {
    question: "¿Puedo cambiar o devolver mi playera?",
    answer: "Aceptamos cambios por talla dentro de los primeros 7 días naturales, siempre que la playera esté sin uso y con etiquetas. Consulta nuestras políticas completas para más detalles.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
};
---

<Layout
  title="Preguntas Frecuentes sobre Pedidos y Envios — Oh Shirt!"
  description="Resolvemos tus dudas sobre tallas, materiales, envios, pagos y devoluciones en Oh Shirt! Todo lo que necesitas saber antes de tu pedido."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header />
  <main id="main-content" class="relative min-h-screen pt-28 pb-16 sm:pt-36">
    <!-- Background glow -->
    <div class="pointer-events-none absolute top-32 left-1/2 -translate-x-1/2 h-64 w-full max-w-[28rem] rounded-full bg-accent/[0.04] blur-[120px]"></div>

    <div class="relative mx-auto max-w-3xl px-4 sm:px-6">
      <Breadcrumb items={breadcrumbs} />
      <!-- Page title -->
      <div class="mb-10 text-center">
        <h1 class="font-brand text-2xl font-normal uppercase tracking-wider text-text sm:text-3xl">
          Preguntas Frecuentes
        </h1>
        <p class="mt-3 text-sm text-text-muted">
          Todo lo que necesitas saber sobre Oh Shirt!
        </p>
      </div>

      <!-- FAQ items -->
      <div class="flex flex-col gap-3">
        {faqs.map((faq, i) => (
          <details
            class="group rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm transition-all duration-200 open:border-accent/20 open:bg-accent/[0.03]"
            style="box-shadow: 0 2px 12px rgba(0,0,0,0.15), inset 0 1px 0 rgba(255,255,255,0.03)"
          >
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 font-display text-sm font-medium text-text transition-colors hover:text-accent sm:px-6 sm:text-base [&::-webkit-details-marker]:hidden">
              <span>{faq.question}</span>
              <svg width="16" height="16" class="shrink-0 text-text-muted transition-transform duration-200 group-open:rotate-45" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </summary>
            <div class="px-5 pb-5 sm:px-6">
              <p class="text-sm leading-relaxed text-text-muted">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-12 text-center">
        <p class="mb-4 text-sm text-text-muted">¿No encontraste lo que buscabas?</p>
        <a
          href="/contacto"
          class="inline-flex items-center gap-2 rounded-2xl border border-accent/30 bg-accent/10 px-6 py-3 font-display text-sm font-semibold uppercase tracking-wider text-accent transition-all duration-200 hover:border-accent/50 hover:bg-accent/20"
        >
          Contáctanos
        </a>
      </div>
    </div>
  </main>
  <Footer />
  <WhatsAppButton />
</Layout>
