---
import Layout from "../layouts/Layout.astro";
import Header from "../components/organisms/Header.astro";
import Footer from "../components/organisms/Footer.astro";
import WhatsAppButton from "../components/organisms/WhatsAppButton.astro";
import Breadcrumb from "../components/atoms/Breadcrumb.astro";

const breadcrumbs = [
  { label: "Inicio", href: "/catalog" },
  { label: "Contacto" },
];

const phone = "5218127261623";
const waMessage = encodeURIComponent("¡Hola! Me interesa una playera del catálogo Oh Shirt!");
const waHref = `https://wa.me/${phone}?text=${waMessage}`;

const quickLinks = [
  { emoji: "👕", text: "Quiero esta playera", msg: "¡Hola! Me interesa una playera del catálogo Oh Shirt!" },
  { emoji: "📏", text: "Dudas de talla", msg: "¡Hola! Tengo una duda sobre las tallas disponibles." },
  { emoji: "🎨", text: "Diseño personalizado", msg: "¡Hola! Me gustaría cotizar un diseño personalizado." },
  { emoji: "📦", text: "Estado de mi pedido", msg: "¡Hola! Quisiera saber el estado de mi pedido." },
];
---

<Layout
  title="Contacto por WhatsApp — Oh Shirt!"
  description="Contactanos por WhatsApp para pedidos, dudas de tallas y disenos personalizados. Respuesta en minutos. Lun-Sab 9am-8pm."
>
  <Header />
  <main id="main-content" class="relative min-h-screen pt-28 pb-20 sm:pt-36">
    <!-- Layered background glows -->
    <div class="pointer-events-none absolute top-24 left-1/2 -translate-x-1/2 h-80 w-full max-w-[36rem] rounded-full bg-accent/[0.04] blur-[140px]"></div>
    <div class="pointer-events-none absolute top-[60%] right-0 h-60 w-full max-w-80 rounded-full bg-[#25d366]/[0.03] blur-[120px]"></div>

    <div class="relative mx-auto max-w-4xl px-4 sm:px-6">
      <Breadcrumb items={breadcrumbs} />

      <!-- ── Page header ── -->
      <div class="mb-12 text-center sm:mb-16">
        <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent/[0.06] px-4 py-1.5 backdrop-blur-sm">
          <div class="h-1.5 w-1.5 rounded-full bg-accent" style="box-shadow: 0 0 8px var(--color-accent)"></div>
          <span class="font-display text-[10px] font-semibold uppercase tracking-[0.2em] text-accent">Respuesta rápida</span>
        </div>
        <h1 class="font-brand text-3xl font-normal uppercase tracking-wider text-text sm:text-4xl lg:text-5xl">
          Hablemos
        </h1>
        <p class="mx-auto mt-4 max-w-md text-sm leading-relaxed text-text-muted sm:text-base">
          ¿Viste algo que te gustó? ¿Quieres un diseño único?<br class="hidden sm:block" />
          Estamos a un mensaje de distancia.
        </p>
      </div>

      <!-- ── WhatsApp Hero CTA ── -->
      <a
        href={waHref}
        target="_blank"
        rel="noopener noreferrer"
        class="wa-hero group relative block overflow-hidden rounded-3xl border border-[#25d366]/20 bg-[#25d366]/[0.04] backdrop-blur-md transition-all duration-500 hover:border-[#25d366]/40 hover:shadow-2xl hover:shadow-[#25d366]/10"
        style="box-shadow: 0 4px 40px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.04)"
      >
        <!-- Accent glow behind card -->
        <div class="pointer-events-none absolute -bottom-20 left-1/2 -translate-x-1/2 h-40 w-80 rounded-full bg-[#25d366]/[0.08] blur-[80px] opacity-50 transition-opacity duration-500 group-hover:opacity-100"></div>

        <!-- Top accent bar -->
        <div class="absolute top-0 left-0 right-0 h-[2px] origin-center scale-x-0 bg-gradient-to-r from-transparent via-[#25d366] to-transparent transition-transform duration-500 ease-out group-hover:scale-x-100"></div>

        <!-- Grid layout: stacked mobile, row desktop -->
        <div class="wa-hero-grid relative">
          <!-- Icon -->
          <div class="wa-hero-icon relative flex items-center justify-center">
            <div
              class="flex h-20 w-20 items-center justify-center rounded-2xl border border-[#25d366]/20 bg-[#25d366]/10 transition-all duration-300 group-hover:scale-105 group-hover:border-[#25d366]/30"
              style="box-shadow: 0 0 30px rgba(37,211,102,0.1)"
            >
              <svg width="40" height="40" class="text-[#25d366]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
              </svg>
            </div>
          </div>

          <!-- Text -->
          <div class="wa-hero-text">
            <h2 class="font-display text-xl font-semibold text-text sm:text-2xl">
              Escríbenos por <span class="text-[#25d366]">WhatsApp</span>
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-text-muted sm:text-base">
              Nuestro canal principal para pedidos, dudas sobre tallas, envíos y diseños personalizados. Te respondemos en minutos.
            </p>
            <!-- Trust badges -->
            <div class="mt-4 flex flex-wrap items-center justify-center gap-3 sm:justify-start">
              <span class="inline-flex items-center gap-1.5 whitespace-nowrap rounded-full border border-white/[0.06] bg-white/[0.03] px-3 py-1 text-[11px] text-text-muted">
                <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#25d366]" style="box-shadow: 0 0 6px #25d366"></span>
                Respuesta en minutos
              </span>
              <span class="inline-flex items-center gap-1.5 whitespace-nowrap rounded-full border border-white/[0.06] bg-white/[0.03] px-3 py-1 text-[11px] text-text-muted">
                <svg width="12" height="12" class="text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2"/><circle cx="12" cy="12" r="10" stroke-linecap="round"/></svg>
                Lun–Sáb · 9am–8pm
              </span>
            </div>
          </div>

          <!-- Arrow CTA -->
          <div class="wa-hero-arrow flex items-center justify-center">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl border border-[#25d366]/30 bg-[#25d366]/10 transition-all duration-300 group-hover:border-[#25d366]/50 group-hover:bg-[#25d366]/20 sm:h-14 sm:w-14">
              <svg width="24" height="24" class="text-[#25d366] transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </div>
          </div>
        </div>
      </a>

      <!-- ── Quick message buttons ── -->
      <div class="mt-6">
        <p class="mb-3 text-center font-display text-[10px] font-semibold uppercase tracking-[0.2em] text-text-muted/50">
          Mensajes rápidos
        </p>
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">
          {quickLinks.map((link) => {
            const msg = encodeURIComponent(link.msg);
            return (
              <a
                href={`https://wa.me/${phone}?text=${msg}`}
                target="_blank"
                rel="noopener noreferrer"
                class="group/q flex items-center gap-2 rounded-xl border border-white/[0.05] bg-white/[0.02] px-3 py-2.5 transition-all duration-200 hover:border-[#25d366]/25 hover:bg-[#25d366]/[0.04]"
              >
                <span class="text-base">{link.emoji}</span>
                <span class="text-xs text-text-muted transition-colors group-hover/q:text-[#25d366]">{link.text}</span>
              </a>
            );
          })}
        </div>
      </div>

      <!-- ── Gradient divider ── -->
      <div class="my-12 flex items-center gap-3 sm:my-16">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-border to-transparent"></div>
        <span class="font-brand text-[10px] font-normal uppercase tracking-[0.2em] text-text-muted/40">También</span>
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-border to-transparent"></div>
      </div>

      <!-- ── Secondary channels grid ── -->
      <div class="grid gap-4 sm:grid-cols-2">
        <!-- Instagram -->
        <a
          href="https://www.instagram.com/oh_shirt_print/"
          target="_blank"
          rel="noopener noreferrer"
          class="card-shine group relative overflow-hidden rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-accent/20 hover:shadow-xl hover:shadow-black/40 sm:p-8"
          style="box-shadow: 0 2px 16px rgba(0,0,0,0.15), inset 0 1px 0 rgba(255,255,255,0.03)"
        >
          <!-- Top accent bar -->
          <div class="absolute top-0 left-0 right-0 h-[2px] origin-center scale-x-0 bg-gradient-to-r from-transparent via-accent to-transparent transition-transform duration-500 ease-out group-hover:scale-x-100"></div>

          <div class="secondary-card-inner">
            <div class="secondary-card-icon flex items-center justify-center rounded-xl border border-accent/20 bg-accent/10 transition-all duration-200 group-hover:border-accent/30 group-hover:scale-105">
              <svg width="24" height="24" class="text-accent" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"></path>
              </svg>
            </div>
            <div class="min-w-0">
              <h2 class="font-display text-base font-semibold text-text sm:text-lg">Instagram</h2>
              <p class="mt-1 text-xs leading-relaxed text-text-muted sm:text-sm">
                Nuevos diseños, detrás de cámaras y promociones exclusivas.
              </p>
              <span class="mt-3 inline-flex items-center gap-1.5 text-xs font-medium text-accent opacity-70 transition-all duration-200 group-hover:gap-2 group-hover:opacity-100">
                @oh_shirt_print
                <svg width="12" height="12" class="text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </span>
            </div>
          </div>
        </a>

        <!-- FAQ link -->
        <a
          href="/faq"
          class="card-shine group relative overflow-hidden rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-white/12 hover:shadow-xl hover:shadow-black/40 sm:p-8"
          style="box-shadow: 0 2px 16px rgba(0,0,0,0.15), inset 0 1px 0 rgba(255,255,255,0.03)"
        >
          <!-- Top accent bar -->
          <div class="absolute top-0 left-0 right-0 h-[2px] origin-center scale-x-0 bg-gradient-to-r from-transparent via-white/20 to-transparent transition-transform duration-500 ease-out group-hover:scale-x-100"></div>

          <div class="secondary-card-inner">
            <div class="secondary-card-icon flex items-center justify-center rounded-xl border border-white/[0.08] bg-white/[0.04] transition-all duration-200 group-hover:border-white/15 group-hover:scale-105">
              <svg width="24" height="24" class="text-text-muted" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="min-w-0">
              <h2 class="font-display text-base font-semibold text-text sm:text-lg">Preguntas Frecuentes</h2>
              <p class="mt-1 text-xs leading-relaxed text-text-muted sm:text-sm">
                Tallas, materiales, envíos, pagos y más. Probablemente ya tenemos la respuesta.
              </p>
              <span class="mt-3 inline-flex items-center gap-1.5 text-xs font-medium text-text-muted transition-all duration-200 group-hover:gap-2 group-hover:text-text">
                Ver FAQ
                <svg width="12" height="12" class="transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      </div>

      <!-- ── Back to catalog nudge ── -->
      <div class="mt-12 text-center sm:mt-16">
        <a
          href="/catalog/todos"
          class="group inline-flex items-center gap-2 rounded-full border border-border/50 bg-surface/30 px-5 py-2.5 transition-all duration-200 hover:border-accent/30 hover:bg-accent/[0.05]"
        >
          <svg width="16" height="16" class="text-text-muted transition-transform duration-200 group-hover:-translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
          </svg>
          <span class="text-xs font-medium text-text-muted transition-colors group-hover:text-accent">Volver al catálogo</span>
        </a>
      </div>

    </div>
  </main>
  <Footer />
  <WhatsAppButton />
</Layout>

<style is:global>
  /* ── WhatsApp hero grid ── */
  .wa-hero-grid {
    display: grid;
    grid-template-areas:
      "icon"
      "text"
      "arrow";
    gap: 1.5rem;
    padding: 2rem;
    text-align: center;
    justify-items: center;
  }

  @media (min-width: 640px) {
    .wa-hero-grid {
      grid-template-columns: auto 1fr auto;
      grid-template-areas: "icon text arrow";
      gap: 2rem;
      padding: 2.5rem;
      text-align: left;
      justify-items: start;
      align-items: center;
    }

    .wa-hero-icon {
      justify-self: center;
    }

    .wa-hero-arrow {
      justify-self: center;
    }
  }

  @media (min-width: 1024px) {
    .wa-hero-grid {
      padding: 3rem;
    }
  }

  .wa-hero-icon { grid-area: icon; }
  .wa-hero-text { grid-area: text; }
  .wa-hero-arrow { grid-area: arrow; }

  /* ── WhatsApp hero shimmer ── */
  .wa-hero {
    position: relative;
  }

  .wa-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(37, 211, 102, 0.03) 45%,
      rgba(37, 211, 102, 0.06) 50%,
      rgba(37, 211, 102, 0.03) 55%,
      transparent 60%
    );
    transform: translateX(-100%);
    transition: transform 0.7s ease;
  }

  .wa-hero:hover::before {
    transform: translateX(100%);
  }

  /* ── Secondary cards layout ── */
  .secondary-card-inner {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1rem;
    align-items: start;
  }

  .secondary-card-icon {
    width: 3rem;
    height: 3rem;
    min-width: 3rem;
  }
</style>
