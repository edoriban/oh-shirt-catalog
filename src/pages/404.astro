---
import Layout from "../layouts/Layout.astro";
import Header from "../components/organisms/Header.astro";
import Footer from "../components/organisms/Footer.astro";
---

<Layout title="Pagina no encontrada — Oh Shirt!" description="La pagina que buscas no existe o fue movida.">
  <Header />
  <main id="main-content" class="relative flex min-h-[70vh] items-center justify-center pt-28 pb-16 sm:pt-36">
    <!-- Background glow -->
    <div class="pointer-events-none absolute top-32 left-1/2 -translate-x-1/2 h-64 w-full max-w-[28rem] rounded-full bg-accent/[0.04] blur-[120px]"></div>

    <div class="relative mx-auto max-w-lg px-4 text-center sm:px-6">
      <p class="mb-4 font-brand text-6xl font-normal text-accent sm:text-8xl">404</p>
      <h1 class="font-brand text-2xl font-normal uppercase tracking-wider text-text sm:text-3xl">
        Pagina no encontrada
      </h1>
      <p class="mt-4 text-sm leading-relaxed text-text-muted sm:text-base">
        Lo sentimos, la pagina que buscas no existe o fue movida.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center gap-2 rounded-2xl border border-accent/30 bg-accent/10 px-6 py-3 font-display text-sm font-semibold uppercase tracking-wider text-accent transition-all duration-200 hover:border-accent/50 hover:bg-accent/20"
      >
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
        </svg>
        Ir al catalogo
      </a>
    </div>
  </main>
  <Footer />
</Layout>
