---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/organisms/Header.astro";
import ProductCard from "../../components/molecules/ProductCard.astro";
import Breadcrumb from "../../components/atoms/Breadcrumb.astro";
import Lightbox from "../../components/organisms/Lightbox.astro";
import Footer from "../../components/organisms/Footer.astro";
import WhatsAppButton from "../../components/organisms/WhatsAppButton.astro";
import CategoryIcon from "../../components/atoms/CategoryIcon.astro";
import { categories } from "../../data/categories";
import { getProductsByCategory, getRandomFromCategory } from "../../data/products";

export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { category: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const products = getProductsByCategory(category.slug);
const randomHero = getRandomFromCategory(category.slug, 1);
const heroProduct = randomHero[0] ?? products[0];

const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Catálogo", href: "/catalog/todos" },
  { label: category.name },
];
---

<Layout
  title={`Playeras de ${category.name} — Oh Shirt!`}
  description={`Descubre ${category.count} disenos exclusivos de playeras de ${category.name}. ${category.description}. Envio a todo Mexico.`}
>
  <Header />
  <main id="main-content">
    <!-- Hero Banner — full width -->
    <section class="relative w-full overflow-hidden pt-[53px]" aria-label={`Colección ${category.name}`}>
      <div class="relative w-full" style="aspect-ratio: 16/5; max-height: 420px;">
        {heroProduct?.image && (
          <Image
            src={heroProduct.image}
            alt=""
            widths={[640, 1024, 1920]}
            sizes="100vw"
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
            decoding="async"
            role="presentation"
          />
        )}

        <!-- Gradient overlays -->
        <div class="absolute inset-0 bg-gradient-to-t from-bg via-bg/50 to-bg/15"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-bg/60 via-transparent to-transparent"></div>

        <!-- Content -->
        <div class="absolute inset-0 flex flex-col justify-end">
          <div class="mx-auto w-full max-w-7xl px-4 pb-8 sm:px-6 sm:pb-10">
            <Breadcrumb items={breadcrumbs} />

            <div class="flex items-end gap-4">
              <div class="flex-1">
                <div class="mb-2 flex items-center gap-2">
                  <div
                    class="flex h-10 w-10 items-center justify-center rounded-xl backdrop-blur-sm"
                    style={`background:${category.accent}20; border: 1px solid ${category.accent}30`}
                    aria-hidden="true"
                  >
                    <CategoryIcon slug={category.slug} color={category.accent} class="h-5 w-5" />
                  </div>
                  <span
                    class="rounded-full px-2.5 py-0.5 text-xs font-semibold backdrop-blur-sm"
                    style={`background:${category.accent}20; color:${category.accent}; border: 1px solid ${category.accent}25`}
                  >
                    {category.count} diseños
                  </span>
                </div>

                <h1
                  id="category-title"
                  class="font-brand text-3xl font-normal uppercase leading-tight tracking-tight text-white drop-shadow-lg sm:text-4xl lg:text-5xl"
                >
                  {category.name}
                </h1>
                <p class="mt-1 text-sm text-white/50 sm:text-base">{category.description}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Search + Product Grid -->
    <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6" aria-label={`Productos de ${category.name}`}>
      <!-- Search bar -->
      <div class="mb-6">
        <div class="relative">
          <svg
            width="16" height="16" class="pointer-events-none absolute top-1/2 left-4 -translate-y-1/2 text-text-muted"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            id="search-input"
            type="search"
            placeholder="Buscar por nombre de personaje..."
            autocomplete="off"
            class="w-full rounded-xl border border-border/60 bg-surface/80 py-3 pl-11 pr-4 font-display text-sm text-text placeholder-text-muted/60 outline-none transition-all duration-200 focus:border-white/20 focus:bg-surface focus:ring-1 focus:ring-white/10"
            aria-label={`Buscar diseños en ${category.name}`}
          />
        </div>
        <p
          id="search-count"
          class="mt-2 hidden text-xs text-text-muted"
          aria-live="polite"
        ></p>
      </div>

      <div
        id="product-grid"
        class="grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-3 lg:grid-cols-4"
        role="list"
      >
        {products.map((product) => <ProductCard product={product} />)}
      </div>

      <p
        id="no-results"
        class="hidden py-16 text-center text-sm text-text-muted"
      >
        No se encontraron diseños con ese nombre.
      </p>
    </section>
  </main>
  <Footer />
  <Lightbox />
  <WhatsAppButton />
</Layout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);
  (window as any).ScrollTrigger = ScrollTrigger;

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (prefersReduced) {
    gsap.set("#category-title", { visibility: "visible", opacity: 1 });
  } else {
    gsap.fromTo(
      "#category-title",
      { autoAlpha: 0, y: 20 },
      { autoAlpha: 1, y: 0, duration: 0.7, ease: "power2.out" }
    );

    // No GSAP batch for product cards — avoids the visible
    // jump-down-then-animate-up flash on first render.
  }

  document.querySelectorAll<HTMLElement>(".product-card").forEach((c) => {
    c.setAttribute("data-revealed", "true");
  });

  // Search filter
  const input = document.getElementById("search-input") as HTMLInputElement;
  const grid = document.getElementById("product-grid")!;
  const noResults = document.getElementById("no-results")!;
  const searchCount = document.getElementById("search-count")!;
  const cards = grid.querySelectorAll<HTMLElement>(".product-card");

  input.addEventListener("input", () => {
    const query = input.value.toLowerCase().trim();
    let visible = 0;

    cards.forEach((card) => {
      const name = (card.dataset.name ?? "").toLowerCase();
      const match = !query || name.includes(query);
      card.style.display = match ? "" : "none";
      if (match) visible++;
    });

    noResults.style.display = visible === 0 && query ? "block" : "none";

    if (query) {
      searchCount.textContent = `${visible} resultado${visible !== 1 ? "s" : ""} para "${input.value.trim()}"`;
      searchCount.classList.remove("hidden");
    } else {
      searchCount.classList.add("hidden");
    }

    if ((window as any).ScrollTrigger) {
      (window as any).ScrollTrigger.refresh();
    }
  });
</script>

<style>
  #category-title {
    visibility: hidden;
  }
</style>
