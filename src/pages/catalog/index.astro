---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/organisms/Header.astro";
import HeroSection from "../../components/organisms/HeroSection.astro";
import ProductCard from "../../components/molecules/ProductCard.astro";
import FranchiseCard from "../../components/molecules/FranchiseCard.astro";
import Lightbox from "../../components/organisms/Lightbox.astro";
import Footer from "../../components/organisms/Footer.astro";
import WhatsAppButton from "../../components/organisms/WhatsAppButton.astro";
import ScrollAnimations from "../../components/organisms/ScrollAnimations.astro";
import { getAllProducts, getRandomFromCategory } from "../../data/products";
import { categories } from "../../data/categories";

// Pick 4 random featured products
const allProducts = getAllProducts();
const shuffled = [...allProducts].sort(() => Math.random() - 0.5);
const featured = shuffled.slice(0, 4);

// Get a representative hero image for each franchise
const franchiseData = categories.map((cat) => {
  const preview = getRandomFromCategory(cat.slug, 1);
  return {
    ...cat,
    heroImage: preview[0].image,
  };
});
---

<Layout>
  <Header />
  <main id="main-content">
    <HeroSection />

    <!-- Featured Products -->
    <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6" aria-labelledby="featured-title">
      <div class="mb-6 flex items-center gap-3">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-border to-transparent"></div>
        <h2
          id="featured-title"
          class="flex items-center gap-2 font-display text-sm font-semibold uppercase tracking-widest text-text-muted"
        >
          <svg class="size-4 text-accent" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L14.5 8.5L21 9.5L16.5 14L17.5 21L12 17.5L6.5 21L7.5 14L3 9.5L9.5 8.5Z" />
          </svg>
          Destacados
        </h2>
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-border to-transparent"></div>
      </div>

      <div
        id="featured-grid"
        class="grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-4"
      >
        {featured.map((product) => <ProductCard product={product} />)}
      </div>

      <!-- CTA to full catalog -->
      <a
        href="/catalog/todos"
        class="group mt-6 flex items-center justify-between rounded-2xl border border-border/50 bg-surface/60 p-4 transition-all duration-300 hover:border-white/10 hover:bg-surface sm:p-5"
      >
        <div>
          <p class="font-display text-sm font-bold tracking-tight text-text sm:text-base">
            Explorar todo el catálogo
          </p>
          <p class="mt-0.5 text-xs text-text-muted">
            {allProducts.length} diseños &middot; {categories.length} franquicias
          </p>
        </div>
        <div class="flex size-10 shrink-0 items-center justify-center rounded-xl border border-border/60 bg-surface transition-all duration-300 group-hover:border-accent/40 group-hover:bg-accent/10 group-hover:text-accent sm:size-11">
          <svg class="size-5 text-text-muted transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </a>
    </section>

    <!-- Franchise Collections -->
    <section class="mx-auto max-w-7xl px-4 pb-12 pt-4 sm:px-6" aria-labelledby="franchises-title">
      <div class="mb-8 flex items-center gap-3">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-border to-transparent"></div>
        <h2
          id="franchises-title"
          class="font-display text-sm font-semibold uppercase tracking-widest text-text-muted"
        >
          Colecciones
        </h2>
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-border to-transparent"></div>
      </div>

      <div id="franchise-grid" class="grid gap-4 sm:grid-cols-2">
        {franchiseData.map((cat) => (
          <FranchiseCard
            slug={cat.slug}
            name={cat.name}
            description={cat.description}
            accent={cat.accent}
            count={cat.count}
            heroImage={cat.heroImage}
          />
        ))}
      </div>
    </section>
  </main>
  <Footer />
  <Lightbox />
  <WhatsAppButton />
  <ScrollAnimations />
</Layout>
