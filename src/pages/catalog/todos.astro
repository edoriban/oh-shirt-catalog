---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/organisms/Header.astro";
import CategoryFilter from "../../components/organisms/CategoryFilter.astro";
import ProductGrid from "../../components/organisms/ProductGrid.astro";
import Lightbox from "../../components/organisms/Lightbox.astro";
import Footer from "../../components/organisms/Footer.astro";
import WhatsAppButton from "../../components/organisms/WhatsAppButton.astro";
import Breadcrumb from "../../components/atoms/Breadcrumb.astro";
import { getAllProducts } from "../../data/products";
import { categories } from "../../data/categories";

const products = getAllProducts();
const totalCount = categories.reduce((sum, c) => sum + c.count, 0);

const breadcrumbs = [
  { label: "Inicio", href: "/catalog" },
  { label: "Catálogo Completo" },
];
---

<Layout
  title="Catálogo Completo — Oh Shirt!"
  description={`Explora nuestro catálogo completo de ${totalCount} playeras con diseños exclusivos de tus franquicias favoritas.`}
>
  <Header />
  <main id="main-content">
    <!-- Page header -->
    <section class="relative overflow-hidden pb-2 pt-28 sm:pt-32">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute top-0 left-1/2 h-[400px] w-[700px] -translate-x-1/2 -translate-y-1/4 rounded-full bg-accent/[0.05] blur-[120px]"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6">
        <Breadcrumb items={breadcrumbs} />

        <h1
          id="page-title"
          class="font-brand text-2xl font-normal uppercase tracking-tight text-text sm:text-3xl"
        >
          Catálogo Completo
        </h1>
        <p class="mt-1 text-sm text-text-muted sm:text-base">
          {totalCount} diseños exclusivos de tus franquicias favoritas
        </p>
      </div>
    </section>

    <CategoryFilter />
    <ProductGrid products={products} />
  </main>
  <Footer />
  <Lightbox />
  <WhatsAppButton />
</Layout>

<script>
  // Pre-fill search from ?q= query param
  const urlParams = new URLSearchParams(window.location.search);
  const qParam = urlParams.get("q");
  if (qParam) {
    const searchInput = document.getElementById("search-input") as HTMLInputElement | null;
    if (searchInput) {
      searchInput.value = qParam;
      searchInput.dispatchEvent(new Event("input"));
      // Scroll to filter area after a tick
      setTimeout(() => searchInput.scrollIntoView({ behavior: "smooth", block: "center" }), 300);
    }
  }
</script>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);
  (window as any).ScrollTrigger = ScrollTrigger;

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (prefersReduced) {
    gsap.set("#page-title, .filter-pill, .category-header", { visibility: "visible", opacity: 1 });
  } else {
    // Page title — immediate on load
    gsap.fromTo(
      "#page-title",
      { autoAlpha: 0, y: 15 },
      { autoAlpha: 1, y: 0, duration: 0.5, ease: "power3.out" }
    );

    // Filter pills — fast stagger
    gsap.fromTo(
      ".filter-pill",
      { autoAlpha: 0, y: 8 },
      { autoAlpha: 1, y: 0, duration: 0.25, stagger: 0.03, ease: "power3.out", delay: 0.15 }
    );

    // Category headers — scroll triggered
    gsap.utils.toArray<HTMLElement>(".category-header").forEach((header) => {
      gsap.fromTo(
        header,
        { autoAlpha: 0, x: -20 },
        {
          autoAlpha: 1,
          x: 0,
          duration: 0.4,
          ease: "power3.out",
          scrollTrigger: {
            trigger: header,
            start: "top 95%",
            toggleActions: "play none none none",
          },
        }
      );
    });

    // No GSAP batch for product cards — ProductGrid handles
    // its own reveal animations via CSS transitions to avoid conflicts.

    window.addEventListener("load", () => ScrollTrigger.refresh());
  }
</script>

<style>
  #page-title,
  .filter-pill,
  .category-header {
    visibility: hidden;
  }
</style>
